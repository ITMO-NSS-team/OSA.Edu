# OpenRouter API key. Create a limited key for this application.
OPENROUTER_API_KEY=

# Optional attribution headers.
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_APP_TITLE=VKR Checker

# Provider data policy. "allow" keeps the widest free-model availability.
# Set "deny" for providers that do not collect data; some free endpoints may become unavailable.
OPENROUTER_DATA_COLLECTION=allow
# Set true to require Zero Data Retention endpoints. This can substantially reduce model availability.
OPENROUTER_ZDR=false

# Keep false for free models. true requires every endpoint to advertise support
# for all optional request parameters and can cause HTTP 404 routing errors.
OPENROUTER_REQUIRE_PARAMETERS=false

# The full block-marked thesis must fit under this character guard and the selected model context.
STRUCTURE_MAX_INPUT_CHARS=2500000

# Grouped semantic checks. Exact and structural rules do not consume LLM calls.
RULES_PER_FRAGMENT_REQUEST=12
CHECK_PACKET_MAX_ATTEMPTS=2

# Conservative OpenRouter client limits. Free endpoints allow at most 20 RPM.
OPENROUTER_MAX_REQUESTS_PER_MINUTE=18
OPENROUTER_MAX_INPUT_TOKENS_PER_MINUTE=0
OPENROUTER_MAX_CONCURRENT_REQUESTS=1
OPENROUTER_MIN_REQUEST_INTERVAL_MS=3400
OPENROUTER_MAX_ATTEMPTS=4
OPENROUTER_MAX_COMPLETION_TOKENS=16000

LLM_CHARS_PER_TOKEN=3
LLM_REQUEST_TIMEOUT_MS=300000

PORT=8787
WEB_ORIGIN=http://127.0.0.1:5173
MAX_FILE_SIZE_MB=35
AUTO_DELETE_SOURCE=true

